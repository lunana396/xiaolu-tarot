{
  "version": 2,
  "builds": [
    {
      "src": "tarot-api/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "tarot-api/**",
          "tarot-data/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/tarot-api/server.js"
    }
  ],
  "env": {
    "TURSO_DATABASE_URL": "@turso_database_url",
    "TURSO_AUTH_TOKEN": "@turso_auth_token",
    "MINIMAX_API_KEY": "@minimax_api_key",
    "JWT_SECRET": "@jwt_secret"
  },
  "buildEnvironmentVars": {
    "TURSO_DATABASE_URL": "@turso_database_url",
    "TURSO_AUTH_TOKEN": "@turso_auth_token",
    "MINIMAX_API_KEY": "@minimax_api_key",
    "JWT_SECRET": "@jwt_secret"
  }
}
